# Mask devel and testing versions by default
=app-shells/bash-99999
=app-shells/bash-supplemental-99999
=app-shells/hist-99999
=app-text/trim-trailing-spaces-99999
=dev-vcs/git-amend-date-using-reference-99999
=dev-vcs/git-checkout-last-version-99999
=dev-vcs/git-diff-blame-99999
=dev-vcs/git-move-99999
=sys-apps/binfind-99999
=sys-apps/hyphenate-99999
=sys-apps/killtree-99999
=sys-apps/libfind-99999
=sys-apps/manfind-99999
=sys-apps/rcopy-99999
=sys-apps/tail-follow-grep-99999
=sys-apps/xn-99999
=sys-block/map-partitions-99999
=sys-boot/build-initramfs-99999

# Mask by default so users won't install them unintentionally.
# Most of these packages are fixed differently from the ones in ::gentoo.
acct-user/pipewire
app-crypt/gnupg
app-portage/repoman
dev-ruby/net-ping
dev-ruby/rubygems
dev-util/geany
media-video/pipewire
media-video/wireplumber
net-irc/hexchat
net-irc/znc
net-wireless/bluez
x11-misc/notification-daemon
